---
// WxQrcodeModal.astro - 微信公众号二维码弹窗
// 全站共用：任意带 [data-wx-modal-trigger] 的元素点击后打开此弹窗
const WX_ID = 'HXiao_Studio';
---

<div
  id="wx-qrcode-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="wx-qrcode-title"
>
  <!-- 磨砂遮罩 -->
  <div
    id="wx-qrcode-overlay"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
  ></div>

  <!-- 居中卡片 -->
  <div
    class="relative w-full max-w-sm bg-bg-sub rounded-2xl border border-border/30 shadow-2xl p-6 text-center"
  >
    <!-- 关闭按钮 -->
    <button
      id="wx-qrcode-close"
      type="button"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full text-text-secondary hover:text-text-primary hover:bg-bg-main/60 transition-colors"
      aria-label="关闭"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <h3 id="wx-qrcode-title" class="text-lg font-serif-cn font-semibold mb-1">
      微信公众号
    </h3>
    <p class="text-xs text-text-secondary mb-4">扫码关注「浮晓 HXiao Studio」</p>

    <!-- 二维码（白底便于扫码） -->
    <div class="bg-white rounded-xl p-3 mx-auto w-fit">
      <img
        src="/assets/qrcode/wx-qrcode.jpg"
        alt="微信公众号「HXiao_Studio」二维码"
        class="w-52 h-52 object-contain"
        width="208"
        height="208"
      />
    </div>

    <!-- ID + 复制 -->
    <div class="mt-5 flex items-center justify-center gap-2">
      <span class="text-sm text-text-secondary">公众号 ID：</span>
      <code class="text-sm font-inter text-text-primary">{WX_ID}</code>
      <button
        id="wx-qrcode-copy"
        type="button"
        class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs bg-accent-sub/20 text-accent hover:bg-accent-sub/40 transition-colors"
        data-wx-id={WX_ID}
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3" />
        </svg>
        <span class="wx-copy-label">复制</span>
      </button>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('wx-qrcode-modal');
  if (modal) {
    const overlay = document.getElementById('wx-qrcode-overlay')!;
    const closeBtn = document.getElementById('wx-qrcode-close')!;
    const copyBtn = document.getElementById('wx-qrcode-copy') as HTMLButtonElement | null;

    const open = () => {
      modal!.classList.remove('hidden');
      modal!.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      modal!.classList.add('hidden');
      modal!.classList.remove('flex');
      document.body.style.overflow = '';
    };

    // 任意 [data-wx-modal-trigger] 元素触发
    document.querySelectorAll('[data-wx-modal-trigger]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    overlay.addEventListener('click', close);
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal!.classList.contains('hidden')) close();
    });

    // 复制公众号 ID（沿用 contact 页的 clipboard + 降级方案）
    if (copyBtn) {
      const label = copyBtn.querySelector('.wx-copy-label')!;
      const id = copyBtn.dataset.wxId || 'HXiao_Studio';
      copyBtn.addEventListener('click', async () => {
        const setCopied = () => {
          label.textContent = '已复制';
          copyBtn.classList.add('text-green-400');
          setTimeout(() => {
            label.textContent = '复制';
            copyBtn.classList.remove('text-green-400');
          }, 2000);
        };
        try {
          await navigator.clipboard.writeText(id);
          setCopied();
        } catch {
          const ta = document.createElement('textarea');
          ta.value = id;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          setCopied();
        }
      });
    }
  }
</script>
