---

<footer class="bg-bg-sub border-t border-border/20 mt-auto">
  <div class="container-main py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Logo + 标语 -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/assets/brand/HXiao_logo.png" alt="HXiao Studio" class="h-8 w-auto" />
          <span class="text-lg font-serif-cn font-semibold">浮晓 HXiao Studio</span>
        </div>
        <p class="text-sm text-text-secondary font-serif-cn italic">
          生如蜉蝣，丈量天光
        </p>
      </div>

      <!-- 导航链接 -->
      <div class="md:col-span-1">
        <h4 class="text-sm font-semibold mb-4 text-text-primary">导航</h4>
        <ul class="grid grid-cols-2 gap-2">
          {footerLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-text-secondary hover:text-accent transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- 社交平台 -->
      <div class="md:col-span-1">
        <h4 class="text-sm font-semibold mb-4 text-text-primary">关注我们</h4>
        <div class="flex items-center gap-4">
          {socialLinks.map(social => (
            social.modal ? (
              <button
                type="button"
                data-wx-modal-trigger
                class="text-text-secondary hover:text-accent transition-colors cursor-pointer"
                aria-label={social.name}
                title={social.name}
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d={social.icon} />
                </svg>
              </button>
            ) : (
              <a 
                href={social.href}
                target={social.href.startsWith('http') ? '_blank' : undefined}
                rel={social.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="text-text-secondary hover:text-accent transition-colors"
                aria-label={social.name}
                title={social.name}
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d={social.icon} />
                </svg>
              </a>
            )
          ))}
        </div>
        <p class="mt-4 text-xs text-text-secondary">
          微信公众号：HXiao_Studio
        </p>
      </div>
    </div>

    <!-- 底部版权 -->
    <div class="mt-12 pt-8 border-t border-border/20 text-center">
      <p class="text-xs text-text-secondary">
        &copy; 2026 浮晓 HXiao Studio &middot; 非营利性创作共同体 &middot; 保留所有权利
      </p>
    </div>
  </div>
</footer>

<!-- 微信公众号二维码弹窗 -->
<WxQrcodeModal />
