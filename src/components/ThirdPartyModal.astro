---
// ThirdPartyModal.astro - 第三方资源声明弹窗
// 全站共用：任意带 [data-third-party-trigger] 的元素点击后打开此弹窗
---

<div
  id="third-party-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="third-party-title"
>
  <!-- 磨砂遮罩 -->
  <div
    id="third-party-overlay"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
  ></div>

  <!-- 居中卡片 -->
  <div
    class="relative w-full max-w-3xl max-h-[85vh] bg-bg-sub rounded-2xl border border-border/30 shadow-2xl flex flex-col"
  >
    <!-- 关闭按钮 -->
    <button
      id="third-party-close"
      type="button"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full text-text-secondary hover:text-text-primary hover:bg-bg-main/60 transition-colors z-10"
      aria-label="关闭"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- 标题 -->
    <div class="p-6 border-b border-border/20">
      <h3 id="third-party-title" class="text-lg font-serif-cn font-semibold">
        第三方资源列表
      </h3>
      <p class="text-xs text-text-secondary mt-1">
        本网站在开发与展示过程中使用了以下第三方资源。
      </p>
    </div>

    <!-- 内容区 -->
    <div class="flex-1 overflow-y-auto p-6 space-y-6 text-sm text-text-secondary no-scrollbar">
      <!-- Tailwind CSS -->
      <section>
        <h4 class="text-base font-serif-cn font-semibold text-text-primary mb-2">1. Tailwind CSS</h4>
        <div class="space-y-1">
          <p><span class="text-text-primary">版权所有：</span>Tailwind Labs, Inc.</p>
          <p><span class="text-text-primary">项目地址：</span><a href="https://github.com/tailwindlabs/tailwindcss" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">https://github.com/tailwindlabs/tailwindcss</a></p>
          <p><span class="text-text-primary">官网：</span><a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">https://tailwindcss.com</a></p>
          <p><span class="text-text-primary">许可证：</span>MIT License</p>
          <p><span class="text-text-primary">用途：</span>CSS 样式框架</p>
        </div>
        <pre class="mt-3 p-3 bg-bg-main/60 rounded-lg text-xs font-mono whitespace-pre-wrap break-words text-text-secondary">MIT License

Copyright (c) Tailwind Labs, Inc.

Permission is hereby granted, free of charge, to any person obtaining a copy
