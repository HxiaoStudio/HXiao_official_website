      </section>

      <hr class="border-border/20" />

      <!-- @astrojs/tailwind -->
      <section>
        <h4 class="text-base font-serif-cn font-semibold text-text-primary mb-2">5. @astrojs/tailwind</h4>
        <div class="space-y-1">
          <p><span class="text-text-primary">版权所有：</span>Astro 团队</p>
          <p><span class="text-text-primary">项目地址：</span><a href="https://github.com/withastro/astro/tree/main/packages/integrations/tailwind" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">https://github.com/withastro/astro/tree/main/packages/integrations/tailwind</a></p>
