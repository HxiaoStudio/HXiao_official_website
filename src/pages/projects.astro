---
// projects.astro - 项目聚合页
import BaseLayout from '../layouts/BaseLayout.astro';

interface ProjectCard {
  name: string;
  type: string;
  status: string;
  statusClass: string;
  description: string;
  license: string;
  platform: string;
  websiteUrl: string;
  githubUrl: string;
  giteeUrl: string;
}

const projectList: ProjectCard[] = [
  {
    name: '取色卡 Color Card',
    type: '开源工具',
    status: '已发布',
    statusClass: 'bg-success/20 text-success',
    description: '一站式本地色彩工具，为摄影师和设计师打造。完全免费、无需联网、无需注册、隐私安全。',
    license: 'GPL-3.0',
    platform: 'Mac M系列 / Win 10/11 X64',
    websiteUrl: 'https://qingshangongzai.github.io/Color_Card',
    githubUrl: 'https://github.com/QingshanGongzai/Color_Card',
    giteeUrl: 'https://gitee.com/HxiaoStudio/Color_Card',
  },
  {
    name: 'BetterGI 星轨',
    type: '开源工具',
    status: '已发布',
    statusClass: 'bg-success/20 text-success',
    description: '专为 BetterGI 打造的键鼠脚本生成与管理工具，基于 PyQt6 开发，提供可视化界面，用于游戏内延时摄影创作。',
    license: 'GPL-3.0',
    platform: 'Windows 10/11 X64',
    websiteUrl: '',
    githubUrl: 'https://github.com/qingshangongzai/BetterGI_StellTrack',
    giteeUrl: 'https://gitee.com/qingshangongzai/BetterGI_StellTrack',
  },
];
---

<BaseLayout title="项目 - 浮晓 HXiao" description="浮晓 HXiao 旗下的开源创作：取色卡 Color Card、BetterGI 星轨等开源项目，完全免费、自由使用。">
  <!-- 页面标题 -->
  <section class="py-16 md:py-24 bg-bg-main">
    <div class="container-main text-center">
      <h1 class="text-3xl md:text-4xl font-serif-cn font-bold mb-6 fade-in-up">
        项目
      </h1>
      <p class="text-text-secondary max-w-2xl mx-auto fade-in-up delay-1">
        浮晓 HXiao 旗下的开源创作，每一个项目都承载着我们的热爱与探索
      </p>
    </div>
  </section>

  <!-- 项目卡片网格 -->
  <section class="section-padding bg-bg-sub">
    <div class="container-main max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 fade-in-up delay-1">

        {projectList.map((project, index) => {
          return (
            <div class="bg-bg-main rounded-2xl border border-border/20 overflow-hidden flex flex-col card-hover fade-in-up" style={`transition-delay: ${index * 0.1}s`}>
              <!-- 卡片头部：类型 + 状态 -->
              <div class="flex items-center justify-between px-6 pt-5">
                <span class="px-2.5 py-1 bg-accent-sub/30 text-accent text-xs font-medium rounded-full">
                  {project.type}
                </span>
                <span class:list={['px-2.5 py-1 text-xs font-medium rounded-full', project.statusClass]}>
                  {project.status}
                </span>
              </div>

              <!-- 卡片主体 -->
              <div class="flex-1 px-6 pt-4 pb-2">
                <h2 class="text-xl font-serif-cn font-bold mb-3">{project.name}</h2>
                <p class="text-sm text-text-secondary leading-relaxed mb-4">{project.description}</p>

                <!-- 项目信息 -->
                <div class="space-y-2 text-sm text-text-secondary">
                  <div class="flex items-center gap-2">
                    <span class="text-border">●</span>
                    <span>开源协议：{project.license}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-border">●</span>
                    <span>支持平台：{project.platform}</span>
                  </div>
                </div>
              </div>

              <!-- 卡片底部：链接按钮 -->
              <div class="px-6 pb-6 pt-4 mt-auto border-t border-border/10">
                <div class="flex flex-wrap gap-2">
                  {project.websiteUrl ? (
                    <a
                      href={project.websiteUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-glow flex-1 px-4 py-2 bg-accent text-text-primary text-sm font-medium rounded-full text-center hover:bg-accent/80 transition-all"
                    >
                      访问官网
                    </a>
                  ) : null}
                  {project.githubUrl ? (
                    <a
                      href={project.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="px-4 py-2 border border-border/40 text-text-secondary text-sm font-medium rounded-full text-center hover:border-accent hover:text-text-primary transition-all"
                    >
                      GitHub
                    </a>
                  ) : null}
                  {project.giteeUrl ? (
                    <a
                      href={project.giteeUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="px-4 py-2 border border-border/40 text-text-secondary text-sm font-medium rounded-full text-center hover:border-accent hover:text-text-primary transition-all"
                    >
                      Gitee
                    </a>
                  ) : null}
                </div>
              </div>
            </div>
          );
        })}

        <!-- 虚位以待占位卡片 -->
        <a href="/join" class="group bg-bg-main rounded-2xl border-2 border-dashed border-accent/30 flex flex-col items-center justify-center p-8 min-h-[280px] hover:border-accent/60 transition-all fade-in-up delay-3">
          <div class="w-16 h-16 rounded-full bg-accent-sub/20 flex items-center justify-center mb-4 group-hover:bg-accent-sub/40 transition-colors">
            <span class="text-3xl text-accent">+</span>
          </div>
          <h3 class="text-lg font-serif-cn font-semibold mb-2">更多项目</h3>
          <p class="text-sm text-text-secondary text-center">
            虚位以待，等待共创者一起发起
          </p>
          <span class="mt-4 text-sm text-accent">加入共创 →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 开源宣言 -->
  <section class="py-16 bg-bg-main text-center">
    <div class="container-main max-w-3xl">
      <blockquote class="text-lg font-serif-cn italic text-text-primary mb-4 fade-in-up">
        我们相信，优秀的工具应该人人可用，优秀的创作应该属于所有人。
      </blockquote>
      <p class="text-text-secondary text-sm fade-in-up delay-1">
        浮晓 HXiao 旗下所有项目均遵循开源精神，任何人可以自由使用、修改和分发。
      </p>
    </div>
  </section>
</BaseLayout>
