---
// contact.astro - 联系页面
import BaseLayout from '../layouts/BaseLayout.astro';

const platforms = [
  { 
    name: 'B站', 
    desc: 'space.bilibili.com/1232406878',
    href: 'https://space.bilibili.com/1232406878',
    icon: 'M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906z'
  },
  { 
    name: '微信公众号', 
    desc: 'HXiao_Studio',
    href: '#',
    modal: true, // 点击后弹出二维码，而非跳转
    icon: 'M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348z'
  },
	  { 
	    name: 'GitHub', 
	    desc: '组织主页',
	    href: 'https://github.com/HxiaoStudio',
	    icon: 'M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z'
	  },
];
---

<BaseLayout title="联系我们 - 浮晓 HXiao">
  <!-- 页面标题 -->
  <section class="py-16 md:py-24 bg-bg-main">
    <div class="container-main text-center">
      <h1 class="text-3xl md:text-4xl font-serif-cn font-bold mb-6 fade-in-up">
        联系我们
      </h1>
      <p class="text-text-secondary max-w-2xl mx-auto fade-in-up delay-1">
        我们欢迎任何真诚的声音
      </p>
    </div>
  </section>

  <!-- 邮件联系引导 -->
  <section class="section-padding bg-bg-sub">
    <div class="container-main max-w-3xl text-center">
      <h2 class="text-2xl font-serif-cn mb-6 fade-in-up">反馈与联系</h2>
      
      <p class="text-text-secondary mb-8 fade-in-up delay-1">
        如果您想提供建议、合作意向或只是想聊一聊，请直接发送邮件至：
      </p>
      
      <div class="bg-bg-main rounded-2xl p-8 md:p-12 border border-border/20 mb-8 fade-in-up delay-2">
        <div class="flex flex-col items-center gap-4">
          <a 
            href="mailto:hxiao_studio@163.com" 
            class="text-2xl md:text-3xl font-serif-cn font-bold text-accent hover:text-accent/80 transition-colors"
            id="email-link"
          >
            hxiao_studio@163.com
          </a>
          
          <button 
            id="copy-email-btn"
            class="btn-glow px-6 py-3 bg-accent text-text-primary font-medium rounded-full hover:bg-accent/80 transition-all text-sm"
          >
            复制邮箱地址
          </button>
          
          <p class="text-sm text-text-secondary mt-4">
            我们会尽力在收到邮件后 3-5 个工作日内回复。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 平台入口 -->
  <section class="section-padding bg-bg-main">
    <div class="container-main max-w-4xl">
      <h2 class="text-2xl font-serif-cn text-center mb-8 fade-in-up">平台入口</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {platforms.map((platform, i) => (
          platform.modal ? (
            <button
              type="button"
              data-wx-modal-trigger
              class="card-hover bg-bg-sub rounded-xl p-6 border border-border/20 text-center cursor-pointer fade-in-up"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent-sub/20 flex items-center justify-center text-accent">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d={platform.icon} />
                </svg>
              </div>
              <h3 class="font-semibold mb-2">{platform.name}</h3>
              <p class="text-sm text-text-secondary">{platform.desc}</p>
              <p class="text-xs text-accent mt-3">点击查看二维码</p>
            </button>
          ) : (
            <a 
              href={platform.href}
              target={platform.href.startsWith('http') ? '_blank' : undefined}
              rel={platform.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="card-hover bg-bg-sub rounded-xl p-6 border border-border/20 text-center block fade-in-up"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent-sub/20 flex items-center justify-center text-accent">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d={platform.icon} />
                </svg>
              </div>
              <h3 class="font-semibold mb-2">{platform.name}</h3>
              <p class="text-sm text-text-secondary">{platform.desc}</p>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- 回应承诺 -->
  <section class="py-16 bg-bg-sub text-center">
    <div class="container-main max-w-3xl">
      <blockquote class="text-lg font-serif-cn italic text-text-primary leading-relaxed fade-in-up">
        在这个账号里，每一个声音都是一束光，我们都在彼此照亮。<br />
        哪怕你只是路过，也欢迎你在评论区分享你对世界的看法，<br />
        或是对我们的视频提出宝贵的建议。<br />
        如需深入交流，欢迎给我们写邮件。
      </blockquote>
    </div>
  </section>
</BaseLayout>

<script>
  // 复制邮箱功能
  const copyBtn = document.getElementById('copy-email-btn');
  
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('hxiao_studio@163.com');
        copyBtn.textContent = '已复制!';
        setTimeout(() => {
          copyBtn.textContent = '复制邮箱地址';
        }, 2000);
      } catch (err) {
        // 降级方案
        const textarea = document.createElement('textarea');
        textarea.value = 'hxiao_studio@163.com';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        copyBtn.textContent = '已复制!';
        setTimeout(() => {
          copyBtn.textContent = '复制邮箱地址';
        }, 2000);
      }
    });
  }
</script>
