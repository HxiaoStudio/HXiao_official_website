---
// members.astro - 成员名单页面
import BaseLayout from '../layouts/BaseLayout.astro';
import membersData from '../data/members.json';

interface Member {
  nickname: string;
  role: string;
  bio?: string;
  joined_at: string;
  avatar?: string;
  links?: { bilibili?: string; github?: string };
  projects?: string[];
}

interface HonoraryMember {
  nickname: string;
  contribution: string;
  period: string;
}

const coreMembers: Member[] = membersData.core_members;
const regularMembers: Member[] = membersData.regular_members;
const honoraryMembers: HonoraryMember[] = membersData.honorary_members;
---

<BaseLayout title="成员名单 - 浮晓 HXiao">
  <!-- 页面标题 -->
  <section class="py-16 md:py-24 bg-bg-main">
    <div class="container-main text-center">
      <h1 class="text-3xl md:text-4xl font-serif-cn font-bold mb-6 fade-in-up">
        成员名单
      </h1>
      <blockquote class="text-lg font-serif-cn italic text-text-secondary max-w-2xl mx-auto fade-in-up delay-1">
        一个人构想的世界是单薄的。<br />
        这里是与我们一同丈量天光刻度的人。
      </blockquote>
    </div>
  </section>

  <!-- 成员分类说明 -->
  <section class="py-12 bg-bg-sub">
    <div class="container-main max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
        <div class="p-4 fade-in-up delay-1">
          <h3 class="font-semibold text-accent mb-2">核心成员</h3>
          <p class="text-sm text-text-secondary">
            长期深度参与，承担组织、协调、决策与日常维护责任
          </p>
        </div>
        <div class="p-4 fade-in-up delay-2">
          <h3 class="font-semibold text-accent mb-2">普通成员</h3>
          <p class="text-sm text-text-secondary">
            认同价值观，参与项目共创，享有提案权、表决权与创作署名权
          </p>
        </div>
        <div class="p-4 fade-in-up delay-3">
          <h3 class="font-semibold text-accent mb-2">荣誉贡献者</h3>
          <p class="text-sm text-text-secondary">
            曾与我们同行，感谢每一份付出
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 核心成员 -->
  <section class="section-padding bg-bg-main">
    <div class="container-main">
      <h2 class="text-2xl font-serif-cn mb-8 fade-in-up">
        <span class="inline-block w-3 h-3 bg-accent rounded-full mr-3"></span>
        核心成员
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {coreMembers.map((member, index) => (
          <div class="card-hover bg-bg-sub rounded-xl border border-border/20 fade-in-up flex flex-col overflow-hidden" style={`transition-delay: ${index * 0.1}s`}>
            <!-- 顶部信息区 -->
            <div class="p-6 pb-4 flex-1">
              <!-- 头像 -->
              <div class="flex justify-center mb-4">
                <a href={member.links?.bilibili || '#'} target="_blank" rel="noopener noreferrer">
                  <img 
                    src={member.avatar || '/assets/brand/HXiao_logo.png'} 
                    alt={member.nickname}
                    class="w-20 h-20 rounded-full object-cover border-2 border-accent/30"
                  />
                </a>
              </div>
              
              <!-- 信息 -->
              <div class="text-center">
                <h3 class="font-semibold text-lg mb-1">{member.nickname}</h3>
                <p class="text-xs text-accent mb-4">{member.role}</p>
                
                {member.bio && (
                  <p class="text-sm text-text-secondary italic leading-relaxed">"{member.bio}"</p>
                )}
                
                <!-- 项目标签 -->
                {member.projects && member.projects.length > 0 && (
                  <div class="flex flex-wrap justify-center gap-2 mt-4">
                    {member.projects.map(project => (
                      <span class="px-2 py-1 bg-accent-sub/20 text-accent text-xs rounded-full">
                        {project}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
            
            <!-- 底部分隔栏：加入时间 + 社交链接 -->
            <div class="border-t border-border/20 bg-bg-main/50 px-6 py-3 flex items-center justify-between">
              <span class="text-xs text-text-secondary">加入于 {member.joined_at}</span>
              
              <!-- 社交链接 -->
              {member.links && (
                <div class="flex items-center gap-2">
                  {member.links.bilibili && (
                    <a href={member.links.bilibili} target="_blank" rel="noopener noreferrer" class="w-7 h-7 rounded-full bg-accent/10 flex items-center justify-center text-accent hover:bg-accent/20 transition-colors" aria-label="B站">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906z"/></svg>
                    </a>
                  )}
                  {member.links.github && (
                    <a href={member.links.github} target="_blank" rel="noopener noreferrer" class="w-7 h-7 rounded-full bg-text-primary/10 flex items-center justify-center text-text-secondary hover:bg-text-primary/20 transition-colors" aria-label="GitHub">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 普通成员 -->
  <section class="section-padding bg-bg-sub">
    <div class="container-main">
      <h2 class="text-2xl font-serif-cn mb-8 fade-in-up">
        <span class="inline-block w-3 h-3 bg-success rounded-full mr-3"></span>
        普通成员
      </h2>
      
      {regularMembers.length > 0 ? (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
          {regularMembers.map((member, index) => (
            <div class="card-hover bg-bg-main rounded-xl p-4 border border-border/20 text-center fade-in-up" style={`transition-delay: ${index * 0.1}s`}>
              <div class="w-14 h-14 rounded-full bg-accent-sub/30 mx-auto mb-3 flex items-center justify-center text-accent text-lg font-semibold">
                {member.nickname.charAt(0)}
              </div>
              <h3 class="font-medium text-sm mb-1">{member.nickname}</h3>
              <p class="text-xs text-text-secondary mb-2">{member.role}</p>
              {member.projects && member.projects.length > 0 && (
                <div class="flex flex-wrap justify-center gap-1 mb-2">
                  {member.projects.map(project => (
                    <span class="px-2 py-0.5 bg-accent-sub/20 text-accent text-xs rounded-full">
                      {project}
                    </span>
                  ))}
                </div>
              )}
              <p class="text-xs text-border">{member.joined_at}</p>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-text-secondary text-lg mb-2">需要你的加入，和我们一起组建团队</p>
          <p class="text-sm text-border">每一个声音，都值得被听见</p>
        </div>
      )}
    </div>
  </section>

  <!-- 荣誉贡献者 -->
  <section class="section-padding bg-bg-main">
    <div class="container-main max-w-3xl">
      <h2 class="text-2xl font-serif-cn mb-8 fade-in-up">
        <span class="inline-block w-3 h-3 bg-border rounded-full mr-3"></span>
        荣誉贡献者
      </h2>
      
      {honoraryMembers.length > 0 ? (
        <div class="space-y-4">
          {honoraryMembers.map((member, index) => (
            <div class="bg-bg-sub rounded-xl p-4 border border-border/20 fade-in-up" style={`transition-delay: ${index * 0.1}s`}>
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="font-medium">{member.nickname}</h3>
                  <p class="text-sm text-text-secondary">{member.contribution}</p>
                </div>
                <span class="text-xs text-border">{member.period}</span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-text-secondary text-center py-8">暂无荣誉贡献者</p>
      )}
    </div>
  </section>

  <!-- 虚位以待 -->
  <section class="section-padding bg-bg-sub text-center">
    <div class="container-main max-w-2xl">
      <div class="bg-bg-main rounded-2xl p-12 border-2 border-dashed border-accent/30 fade-in-up">
        <div class="w-20 h-20 rounded-full bg-accent-sub/20 mx-auto mb-6 flex items-center justify-center">
          <span class="text-3xl text-accent">?</span>
        </div>
        <h2 class="text-2xl font-serif-cn font-semibold mb-4">
          下一位成员，会是你吗？
        </h2>
        <p class="text-text-secondary mb-8">
          你也想出现在这里？与我们一同丈量天光的刻度。
        </p>
        <a 
          href="/join" 
          class="btn-glow inline-block px-8 py-4 bg-accent text-text-primary font-medium rounded-full hover:bg-accent/80 transition-all"
        >
          加入共创 →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
