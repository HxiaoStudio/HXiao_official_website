---
// works.astro - 内容作品页面
import BaseLayout from '../layouts/BaseLayout.astro';
import videoEntries from '../data/videos.json';
import articles from '../data/articles.json';
import { fetchVideoMeta, formatPlay } from '../utils/bilibili';
import type { VideoMeta } from '../utils/bilibili';

const videos: VideoMeta[] = (
  await Promise.all(
    videoEntries.map((entry: { bvid: string }) => fetchVideoMeta(entry.bvid))
  )
).filter((v): v is VideoMeta => v !== null);
---

<BaseLayout title="内容作品 - 浮晓 HXiao">
  <!-- 页面标题 -->
  <section class="py-16 md:py-24 bg-bg-main">
    <div class="container-main text-center">
      <h1 class="text-3xl md:text-4xl font-serif-cn font-bold mb-6 fade-in-up">
        内容作品
      </h1>
      <p class="text-text-secondary max-w-2xl mx-auto fade-in-up delay-1">
        记录微小日常的脉搏，探寻广阔世界的模样
      </p>
    </div>
  </section>

  <!-- B站视频精选 -->
  <section class="section-padding bg-bg-main">
    <div class="container-main">
      <h2 class="text-2xl md:text-3xl font-serif-cn mb-8 fade-in-up">
        B站视频精选
      </h2>

      {videos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {videos.map((video, index) => (
            <a
              href={`https://www.bilibili.com/video/${video.bvid}`}
              target="_blank"
              rel="noopener noreferrer"
              class="block bg-bg-sub rounded-xl overflow-hidden border border-border/20 hover:border-accent/50 transition-all group fade-in-up"
              style={`transition-delay: ${index * 0.05}s`}
            >
              <div class="aspect-video bg-bg-sub relative overflow-hidden">
                <img
                  src={video.pic}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
              </div>
              <div class="p-4">
                <h3 class="font-medium text-sm mb-2 line-clamp-2 group-hover:text-accent transition-colors">{video.title}</h3>
                <div class="flex items-center gap-4 text-xs text-text-secondary">
                  <span>▶ {formatPlay(video.play)}</span>
                  <span>{video.date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-text-secondary text-center py-8">
          暂无视频，请访问我们的
          <a href="https://space.bilibili.com/1232406878" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">B站主页</a>
        </p>
      )}
    </div>
  </section>

  <!-- 公众号精选 -->
  <section class="section-padding bg-bg-sub">
    <div class="container-main max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-serif-cn mb-8 fade-in-up">
        公众号文章精选
      </h2>
      
      <div class="space-y-6">
        {articles.map((article, index) => (
          <a href={article.url} target="_blank" rel="noopener noreferrer" class="block bg-bg-main rounded-xl p-6 border border-border/20 card-hover fade-in-up" style={`transition-delay: ${index * 0.1}s`}>
            <div class="flex justify-between items-start gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-semibold mb-2">{article.title}</h3>
                <p class="text-text-secondary text-sm mb-3 line-clamp-2">{article.summary}</p>
                <time class="text-xs text-border">{article.date}</time>
              </div>
              <span class="flex-shrink-0 text-accent text-sm">阅读 →</span>
            </div>
          </a>
        ))}
      </div>
      
      <div class="mt-8 text-center">
        <button type="button" data-wx-modal-trigger class="text-sm text-text-secondary hover:text-accent transition-colors cursor-pointer">
          关注公众号 <strong class="text-text-primary">HXiao_Studio</strong> 阅读更多
        </button>
      </div>
    </div>
  </section>

  <!-- 内容理念 -->
  <section class="py-16 bg-bg-main text-center">
    <div class="container-main max-w-3xl">
      <blockquote class="text-xl md:text-2xl font-serif-cn italic text-text-primary fade-in-up">
        「记录微小日常的脉搏，探寻广阔世界的模样」
      </blockquote>
    </div>
  </section>
</BaseLayout>
