---
// charter.astro - 工作室章程页面
// 章程内容从 src/data/charter.md 动态加载
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content, frontmatter } from '../data/charter.md';

const chapters = frontmatter.chapters;
---

<BaseLayout title="工作室章程 - 浮晓 HXiao">
  <!-- 页面标题 -->
  <section class="py-16 md:py-24 bg-bg-main">
    <div class="container-main text-center">
      <h1 class="text-3xl md:text-4xl font-serif-cn font-bold mb-6 fade-in-up">
        工作室章程
      </h1>
      <!-- 状态标识 -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-hover/30 rounded-full text-sm text-text-primary fade-in-up delay-1">
        <span>⚠️</span>
        <span><strong>临时章程</strong> — 待成员构成完整后咨询社员意见进行修订</span>
      </div>
    </div>
  </section>

  <!-- 主体内容 -->
  <section class="section-padding bg-bg-main">
    <div class="container-main">
      <div class="flex gap-8 max-w-6xl mx-auto">
        
        <!-- 右侧悬浮目录（桌面端） -->
        <aside class="hidden lg:block w-56 flex-shrink-0">
          <div class="sticky top-24">
            <h3 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4">章节目录</h3>
            <nav class="space-y-2">
              {chapters.map(ch => (
                <a href={`#${ch.id}`} class="block text-sm text-text-secondary hover:text-accent transition-colors py-1">
                  {ch.title}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- 章程正文 -->
        <div class="flex-1 max-w-3xl">
          <article class="charter-content">
            <Content />
          </article>

          <!-- 生效信息 -->
          <div class="mt-12 pt-8 border-t border-border/20 text-center text-text-secondary text-sm">
            <p class="font-serif-cn">{frontmatter.studioName}</p>
            <p class="mt-2">生效日期：{frontmatter.effectiveDate}</p>
            <p class="mt-1 text-xs">{frontmatter.footerNote}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .charter-content :global(h2) {
    @apply scroll-mt-24 text-2xl font-serif-cn font-bold mb-6 pb-3 mt-12 border-b-2 border-solid border-accent/30;
  }
  .charter-content :global(h2:first-of-type) {
    margin-top: 0;
  }
  .charter-content :global(h3) {
    @apply font-semibold text-lg mb-3;
  }
  .charter-content :global(ol) {
    @apply list-decimal list-inside text-text-secondary;
  }
  .charter-content :global(ul) {
    @apply list-disc list-inside text-text-secondary;
  }
  .charter-content :global(li) {
    @apply my-1;
  }
  .charter-content :global(p) {
    @apply text-text-secondary;
  }
</style>
